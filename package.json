{
  "name": "datadock",
  "version": "0.1.5",
  "description": "DataDock — a project/environment-organized database client",
  "main": "./out/main/index.js",
  "author": "Alessio De Houwer",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "rebuild": "CXXFLAGS=\"-isystem $(xcrun --show-sdk-path)/usr/include/c++/v1\" CFLAGS=\"-isystem $(xcrun --show-sdk-path)/usr/include/c++/v1\" electron-rebuild -f --only better-sqlite3",
    "postinstall": "npm run rebuild || true",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "pack": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "be.devium.datadock",
    "productName": "DataDock",
    "copyright": "Free to use © Devium",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "deviumbe",
        "repo": "datadock"
      }
    ],
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "npmRebuild": false,
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/better-sqlite3/**"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "Install DataDock",
      "icon": "build/icon.icns",
      "iconSize": 128,
      "window": {
        "x": 100,
        "y": 100,
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 185,
          "type": "file"
        },
        {
          "x": 390,
          "y": 185,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@influxdata/influxdb-client": "^1.35.0",
    "@influxdata/influxdb-client-apis": "^1.35.0",
    "better-sqlite3": "^11.8.1",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mongodb": "^6.21.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.12.0",
    "openai": "^4.104.0",
    "papaparse": "^5.5.3",
    "pg": "^8.13.1",
    "sql-formatter": "^15.8.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.2",
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.10.7",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.11.10",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "pinia": "^2.3.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
